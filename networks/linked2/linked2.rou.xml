<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="13.89"/>
    <vType id="emergency" accel="3.0" decel="6.0" sigma="0.0" length="5" maxSpeed="16.67" color="1,0,0"/>

    <!-- Primary East-West corridor through Int3-Int1-Int4 -->
    <route id="W_to_E" edges="Int3_W2C Int3_Int1 Int1_Int4 Int4_C2E"/>
    <route id="E_to_W" edges="Int4_E2C Int4_Int1 Int1_Int3 Int3_C2W"/>

    <!-- North-South through Int2-Int1-Int5 -->
    <route id="N_to_S" edges="Int2_N2C Int2_Int1 Int1_Int5 Int5_C2S"/>
    <route id="S_to_N" edges="Int5_S2C Int5_Int1 Int1_Int2 Int2_C2N"/>

    <!-- Diagonal through Int3-Int1-Int6 -->
    <route id="NW_to_SE" edges="Int3_NW2C Int3_Int1 Int1_Int6 Int6_C2S"/>
    <route id="SE_to_NW" edges="Int6_S2C Int6_Int1 Int1_Int3 Int3_C2NW"/>

    <!-- Local Int2 routes -->
    <route id="Int2_E_in"  edges="Int2_E2C Int2_C2N"/>
    <route id="Int2_E_out" edges="Int2_N2C Int2_C2E"/>

    <!-- Local Int3 routes -->
    <route id="Int3_N_in" edges="Int3_N2C Int3_C2W"/>
    <route id="Int3_S_in" edges="Int3_S2C Int3_C2W"/>

    <!-- Local Int4 routes -->
    <route id="Int4_N_in" edges="Int4_N2C Int4_C2E"/>
    <route id="Int4_S_in" edges="Int4_S2C Int4_C2E"/>

    <!-- Local Int6 routes -->
    <route id="Int6_N_in" edges="Int6_N2C Int6_C2E"/>

    <!-- EV corridor West to East through network -->
    <route id="EV_WE" edges="Int3_W2C Int3_Int1 Int1_Int4 Int4_C2E"/>
    <!-- EV diagonal corridor -->
    <route id="EV_diag" edges="Int6_N2C Int6_Int1 Int1_Int3 Int3_C2W"/>

    <!-- Main flows -->
    <flow id="flow_WE"     type="car" route="W_to_E"    begin="0" end="999999" vehsPerHour="200"/>
    <flow id="flow_EW"     type="car" route="E_to_W"    begin="0" end="999999" vehsPerHour="200"/>
    <flow id="flow_NS"     type="car" route="N_to_S"    begin="0" end="999999" vehsPerHour="150"/>
    <flow id="flow_SN"     type="car" route="S_to_N"    begin="0" end="999999" vehsPerHour="150"/>
    <flow id="flow_NW_SE"  type="car" route="NW_to_SE"  begin="0" end="999999" vehsPerHour="80"/>
    <flow id="flow_SE_NW"  type="car" route="SE_to_NW"  begin="0" end="999999" vehsPerHour="80"/>

    <!-- Local flows -->
    <flow id="flow_Int2_E"  type="car" route="Int2_E_in"  begin="0" end="999999" vehsPerHour="60"/>
    <flow id="flow_Int2_E2" type="car" route="Int2_E_out" begin="0" end="999999" vehsPerHour="60"/>
    <flow id="flow_Int3_N"  type="car" route="Int3_N_in"  begin="0" end="999999" vehsPerHour="50"/>
    <flow id="flow_Int3_S"  type="car" route="Int3_S_in"  begin="0" end="999999" vehsPerHour="50"/>
    <flow id="flow_Int4_N"  type="car" route="Int4_N_in"  begin="0" end="999999" vehsPerHour="40"/>
    <flow id="flow_Int4_S"  type="car" route="Int4_S_in"  begin="0" end="999999" vehsPerHour="40"/>
    <flow id="flow_Int6_N"  type="car" route="Int6_N_in"  begin="0" end="999999" vehsPerHour="30"/>

    <!-- Emergency vehicles -->
    <flow id="flow_EV_WE"   type="emergency" route="EV_WE"   begin="200" end="999999" vehsPerHour="2"/>
    <flow id="flow_EV_diag" type="emergency" route="EV_diag" begin="500" end="999999" vehsPerHour="1"/>

</routes>