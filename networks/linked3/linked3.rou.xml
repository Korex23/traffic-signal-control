<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="13.89"/>
    <vType id="emergency" accel="3.0" decel="6.0" sigma="0.0" length="5" maxSpeed="16.67" color="1,0,0"/>

    <!-- Primary W-E corridor -->
    <route id="W_to_E"   edges="Int3_W2C Int3_Int1 Int1_Int4 Int4_C2E"/>
    <route id="E_to_W"   edges="Int4_E2C Int4_Int1 Int1_Int3 Int3_C2W"/>

    <!-- NE one-way heavy inflow through Int7 -->
    <route id="NE_to_W"  edges="Int7_N2C Int7_Int1 Int1_Int3 Int3_C2W"/>
    <route id="E_to_NE"  edges="Int4_E2C Int4_Int1 Int1_Int7 Int7_C2N"/>

    <!-- N-S through Int2-Int1-Int5 -->
    <route id="N_to_S"   edges="Int2_N2C Int2_Int1 Int1_Int5 Int5_C2S"/>
    <route id="S_to_N"   edges="Int5_S2C Int5_Int1 Int1_Int2 Int2_C2N"/>

    <!-- Diagonal through Int6 -->
    <route id="NW_to_SE" edges="Int3_NW2C Int3_Int1 Int1_Int6 Int6_C2S"/>
    <route id="SE_to_E"  edges="Int6_S2C Int6_Int1 Int1_Int4 Int4_C2E"/>

    <!-- Local routes -->
    <route id="Int3_N_loc" edges="Int3_N2C Int3_C2W"/>
    <route id="Int3_S_loc" edges="Int3_S2C Int3_C2W"/>
    <route id="Int4_N_loc" edges="Int4_N2C Int4_C2E"/>
    <route id="Int4_S_loc" edges="Int4_S2C Int4_C2E"/>
    <route id="Int2_W_loc" edges="Int2_W2C Int2_C2N"/>
    <route id="Int5_W_loc" edges="Int5_W2C Int5_C2S"/>
    <route id="Int7_E_loc" edges="Int7_E2C Int7_C2N"/>

    <!-- EV corridor W to E full network -->
    <route id="EV_WE"   edges="Int3_W2C Int3_Int1 Int1_Int4 Int4_C2E"/>
    <!-- EV diagonal -->
    <route id="EV_diag" edges="Int7_N2C Int7_Int1 Int1_Int5 Int5_C2S"/>

    <!-- Main flows -->
    <flow id="flow_WE"     type="car" route="W_to_E"    begin="0" end="999999" vehsPerHour="200"/>
    <flow id="flow_EW"     type="car" route="E_to_W"    begin="0" end="999999" vehsPerHour="200"/>
    <flow id="flow_NE_W"   type="car" route="NE_to_W"   begin="0" end="999999" vehsPerHour="150"/>
    <flow id="flow_E_NE"   type="car" route="E_to_NE"   begin="0" end="999999" vehsPerHour="100"/>
    <flow id="flow_NS"     type="car" route="N_to_S"    begin="0" end="999999" vehsPerHour="120"/>
    <flow id="flow_SN"     type="car" route="S_to_N"    begin="0" end="999999" vehsPerHour="120"/>
    <flow id="flow_NW_SE"  type="car" route="NW_to_SE"  begin="0" end="999999" vehsPerHour="80"/>
    <flow id="flow_SE_E"   type="car" route="SE_to_E"   begin="0" end="999999" vehsPerHour="80"/>

    <!-- Local flows -->
    <flow id="flow_Int3_N" type="car" route="Int3_N_loc" begin="0" end="999999" vehsPerHour="50"/>
    <flow id="flow_Int3_S" type="car" route="Int3_S_loc" begin="0" end="999999" vehsPerHour="50"/>
    <flow id="flow_Int4_N" type="car" route="Int4_N_loc" begin="0" end="999999" vehsPerHour="40"/>
    <flow id="flow_Int4_S" type="car" route="Int4_S_loc" begin="0" end="999999" vehsPerHour="40"/>
    <flow id="flow_Int2_W" type="car" route="Int2_W_loc" begin="0" end="999999" vehsPerHour="30"/>
    <flow id="flow_Int5_W" type="car" route="Int5_W_loc" begin="0" end="999999" vehsPerHour="30"/>
    <flow id="flow_Int7_E" type="car" route="Int7_E_loc" begin="0" end="999999" vehsPerHour="60"/>

    <!-- Emergency vehicles -->
    <flow id="flow_EV_WE"   type="emergency" route="EV_WE"   begin="200" end="999999" vehsPerHour="2"/>
    <flow id="flow_EV_diag" type="emergency" route="EV_diag" begin="600" end="999999" vehsPerHour="1"/>

</routes>